{
  "manifest_version": 3,
  "name": "TripAnchor",
  "version": "0.1.0",
  "description": "Collect places from any webpage while planning a trip and export them to Google My Maps in one click.",
  "permissions": [
    "storage",
    "contextMenus",
    "downloads",
    "scripting",
    "activeTab",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "TripAnchor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
